{
  "chart_type": "timeline",
  "canvas": {
    "width": 800,
    "height": 1200,
    "background": "#FDFEFE"
  },
  "color_scheme": {
    "name": "学术稳重",
    "primary": "#8E44AD",
    "secondary": "#2C3E50",
    "accent": "#E74C3C",
    "background": "#FDFEFE",
    "text_primary": "#1a1a2e",
    "text_secondary": "#636e72",
    "palette": [
      "#8E44AD",
      "#2C3E50",
      "#E74C3C",
      "#3498DB",
      "#27AE60",
      "#F39C12"
    ],
    "rationale": "紫色象征权威与历史积淀，契合百年名校的厚重感；深蓝灰作为辅助色增强稳定感；红色点缀突出重要里程碑事件（建校、合并、百年校庆），形成视觉焦点。"
  },
  "typography": {
    "title_size": 36,
    "heading_size": 24,
    "body_size": 16,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 12,
    "rows": 24,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "放置主标题 '中山大学发展历程'，采用大号紫色字体，居中显示，下方可加细线装饰"
    },
    {
      "id": "subtitle_section",
      "type": "content_block",
      "position": {
        "x_pct": 10,
        "y_pct": 10,
        "width_pct": 80,
        "height_pct": 5
      },
      "visual_weight": "secondary",
      "purpose": "展示学校百年发展概述，文字采用正文大小，居中对齐，颜色为辅助文本色"
    },
    {
      "id": "timeline_section",
      "type": "timeline",
      "position": {
        "x_pct": 0,
        "y_pct": 15,
        "width_pct": 100,
        "height_pct": 80
      },
      "visual_weight": "primary",
      "purpose": "包含中心垂直时间轴、12个事件节点和左右交错的事件卡片，构成核心叙事区域"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 0,
        "y_pct": 95,
        "width_pct": 100,
        "height_pct": 5
      },
      "visual_weight": "tertiary",
      "purpose": "显示数据来源注释 '来源：中山大学官网'，小字右对齐"
    }
  ],
  "elements": [
    {
      "id": "main_title",
      "type": "text_block",
      "label": "中山大学发展历程",
      "parent_section": "title_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "主标题，居中放置于title_section，使用36px Bold字体，颜色 primary (#8E44AD)，下方可加一条短横线装饰"
    },
    {
      "id": "overview_text",
      "type": "text_block",
      "label": "中山大学由孙中山先生于1924年创办，是中国南方最著名的高等学府之一。历经百年发展，学校从单一校区扩展为三校区五校园的宏大格局。2001年与中山医科大学合并后学科更加齐全，2017年入选国家双一流建设高校A类，2024年迎来百年华诞。",
      "parent_section": "subtitle_section",
      "color_key": "text_secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 600,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "概述文字，居中对齐，16px Regular，颜色 text_secondary (#636e72)，行间距适中"
    },
    {
      "id": "center_line",
      "type": "line",
      "label": null,
      "parent_section": "timeline_section",
      "color_key": "secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 4,
        "min_height": 900,
        "aspect_ratio": null
      },
      "content_hint": "竖向时间轴主线，位于画布水平中心 (x=50%)，从 timeline_section 顶部延伸至底部，使用 secondary (#2C3E50) 颜色，宽度4px，实线"
    },
