{
  "chart_type": "timeline",
  "canvas": {
    "width": 800,
    "height": 1200,
    "background": "#F8FAFC"
  },
  "color_scheme": {
    "name": "学术稳重",
    "primary": "#1E3A8A",
    "secondary": "#5B21B6",
    "accent": "#B91C1C",
    "background": "#F8FAFC",
    "text_primary": "#1E293B",
    "text_secondary": "#64748B",
    "palette": [
      "#1E3A8A",
      "#5B21B6",
      "#B91C1C",
      "#0EA5E9",
      "#10B981"
    ],
    "rationale": "以深蓝(#1E3A8A)和深红(#B91C1C)为核心的学术稳重配色。深蓝代表历史沉淀与学术严谨，呼应中山大学的学术权威感；深红作为强调色，呼应中大标志性色彩，同时用于高亮关键时间节点，引导视觉沿时间轴前行。背景采用极浅蓝灰(#F8FAFC)营造清爽、专注的阅读体验，文本采用深灰蓝(#1E293B)确保高可读性。"
  },
