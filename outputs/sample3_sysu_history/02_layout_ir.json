    "title_size": 32,
    "heading_size": 22,
    "body_size": 16,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 5,
    "rows": 10,
    "gutter": 20
  },
