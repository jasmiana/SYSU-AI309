{
  "chart_type": "timeline",
  "canvas": {
    "width": 800,
    "height": 1000,
    "background": "#FDFEFE"
  },
  "color_scheme": {
    "name": "学术稳重",
    "primary": "#8E44AD",
    "secondary": "#2C3E50",
    "accent": "#E74C3C",
    "background": "#FDFEFE",
    "text_primary": "#1a1a2e",
    "text_secondary": "#636e72",
    "palette": [
      "#8E44AD",
      "#2C3E50",
      "#E74C3C",
      "#3498DB",
      "#27AE60"
    ],
    "rationale": "紫色调体现历史底蕴与学术稳重，适合大学发展历程主题，辅以深灰与红色强调关键节点和事件"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 20,
    "body_size": 14,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 1,
    "rows": 8,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示主标题和副标题"
    },
    {
      "id": "timeline_section",
      "type": "diagram",
      "position": {
        "x_pct": 0,
        "y_pct": 10,
        "width_pct": 100,
        "height_pct": 85
      },
      "visual_weight": "primary",
      "purpose": "垂直时间线主体，包含时间轴、事件节点和描述文本"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 0,
        "y_pct": 95,
        "width_pct": 100,
        "height_pct": 5
      },
      "visual_weight": "tertiary",
      "purpose": "注释与数据来源"
    }
  ],
  "elements": [
