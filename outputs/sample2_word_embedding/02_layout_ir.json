{
  "chart_type": "concept_map",
  "canvas": {
    "width": 800,
    "height": 1200,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "柔和蓝紫渐变",
    "primary": "#6C63FF",
    "secondary": "#4A90D9",
    "accent": "#FF6B6B",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#6C63FF",
      "#4A90D9",
      "#27AE60",
      "#F39C12",
      "#E74C3C"
    ],
    "rationale": "目标受众为不了解NLP的大众，柔和蓝紫色系传递科技感且友好，渐变背景增强层次感，多色板用于散点图语义类别区分。"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 22,
    "body_size": 15,
    "label_size": 13,
    "font_family": "system-ui, 'Microsoft YaHei', -apple-system, sans-serif"
  },
  "layout_grid": {
    "columns": 4,
    "rows": 12,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 5,
        "y_pct": 0,
        "width_pct": 90,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示主标题和副标题，吸引注意力"
    },
    {
      "id": "upper_section",
      "type": "content_block",
      "position": {
        "x_pct": 5,
        "y_pct": 10,
        "width_pct": 90,
        "height_pct": 25
      },
      "visual_weight": "secondary",
      "purpose": "解释什么是词向量，包含文字描述和数字向量示例"
    },
    {
      "id": "middle_section",
      "type": "diagram",
      "position": {
        "x_pct": 5,
        "y_pct": 35,
        "width_pct": 90,
        "height_pct": 35
      },
      "visual_weight": "primary",
      "purpose": "展示词向量语义空间散点图（2D投影），突出语义相似性"
    },
    {
      "id": "lower_section",
      "type": "diagram",
      "position": {
        "x_pct": 5,
        "y_pct": 70,
        "width_pct": 90,
        "height_pct": 22
      },
      "visual_weight": "secondary",
      "purpose": "展示词向量类比示例（king - man + woman ≈ queen）"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 5,
        "y_pct": 92,
        "width_pct": 90,
        "height_pct": 8
      },
      "visual_weight": "tertiary",
      "purpose": "放置来源注释和版本信息"
    }
  ],
  "elements": [
    {
      "id": "main_title",
      "type": "text_block",
      "label": "词向量（Word Embedding）基本概念通俗解释",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 500,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "主标题，居中加粗显示"
    },
    {
      "id": "subtitle",
      "type": "text_block",
      "label": "让计算机理解词语含义的魔法",
      "parent_section": "title_section",
      "color_key": "text_secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 300,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "副标题，位于主标题下方，颜色稍淡"
    },
    {
      "id": "upper_intro_text",
      "type": "text_block",
      "label": "词向量将每个单词映射为固定长度的稠密向量，例如“苹果”可以表示为 [0.2, 0.8, -0.3, 0.5, ...]。这些数字代表词的语义特征，使得意义相近的词向量距离更近。独热编码是早期方法，但维度高、无法表达相似性；词向量则解决了这一问题。",
      "parent_section": "upper_section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 400,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "解释性文字，段落形式，左侧排列"
    },
    {
      "id": "vector_demo_rect",
      "type": "rounded_rect",
      "label": "",
      "parent_section": "upper_section",
      "color_key": "primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": "2.5"
      },
      "content_hint": "圆角矩形框，背景色使用primary（半透明或浅色），内部显示向量数字"
    },
    {
      "id": "vector_demo_text",
      "type": "text_block",
      "label": "[0.2, 0.8, -0.3, 0.5, ...]",
      "parent_section": "upper_section",
      "color_key": "text_primary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 150,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "等宽字体显示向量数字，放在vector_demo_rect内部居中"
    },
    {
      "id": "scatter_axis_x",
      "type": "axis",
      "label": "PC1",
      "parent_section": "middle_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 300,
        "min_height": 8,
        "aspect_ratio": null
      },
      "content_hint": "横轴，标注主成分1"
