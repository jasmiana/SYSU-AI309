{
  "chart_type": "concept_map",
  "canvas": {
    "width": 800,
    "height": 1200,
    "background": "#F4F6FF"
  },
  "color_scheme": {
    "name": "柔和蓝紫渐变",
    "primary": "#6C63FF",
    "secondary": "#9B8EFF",
    "accent": "#FF6584",
    "background": "#F4F6FF",
    "text_primary": "#2C2C54",
    "text_secondary": "#6D6D8A",
    "palette": [
      "#6C63FF",
      "#9B8EFF",
      "#FF6584",
      "#F0A500",
      "#00B4D8"
    ],
    "rationale": "选用蓝紫渐变表达科技与柔和的平衡，适合面向大众的科普概念图，通过暖色点缀增强关键信息"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 22,
    "body_size": 16,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 3,
    "rows": 5,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 5,
        "y_pct": 2,
        "width_pct": 90,
        "height_pct": 8
      },
      "visual_weight": "primary",
      "purpose": "展示主标题和副标题，吸引注意力"
    },
    {
      "id": "concept_intro",
      "type": "content_block",
      "position": {
        "x_pct": 5,
        "y_pct": 12,
        "width_pct": 90,
        "height_pct": 22
      },
      "visual_weight": "primary",
      "purpose": "解释词向量的基本概念，展示独热编码对比和分布式表示示例"
    },
    {
      "id": "semantic_space",
      "type": "diagram",
      "position": {
        "x_pct": 5,
        "y_pct": 36,
        "width_pct": 90,
        "height_pct": 32
      },
      "visual_weight": "primary",
      "purpose": "展示2D语义空间散点图，包含不同颜色聚类的词点和虚线聚类边界"
    },
    {
      "id": "analogy_demo",
      "type": "diagram",
      "position": {
        "x_pct": 5,
        "y_pct": 70,
        "width_pct": 90,
        "height_pct": 22
      },
      "visual_weight": "secondary",
      "purpose": "演示 king - man + woman ≈ queen 的类比关系，包含向量箭头和公式"
    },
    {
      "id": "footer_notes",
      "type": "footer",
      "position": {
        "x_pct": 5,
        "y_pct": 93,
        "width_pct": 90,
        "height_pct": 5
      },
      "visual_weight": "tertiary",
      "purpose": "提供注释、数据来源和额外说明"
    }
  ],
  "elements": [
    {
      "id": "main_title",
      "type": "text_block",
      "label": "词向量（Word Embedding）基本概念解析",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 600,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "主标题居中显示，下方可加一行小字副标题：NLP基础・语义表示技术"
    },
    {
      "id": "intro_text",
      "type": "text_block",
      "label": "词向量是将单词映射为稠密实数向量的技术，能捕捉语义和句法信息。相比独热编码（高维稀疏），词向量维度低、表达力强，且可通过余弦相似度度量语义关系。",
      "parent_section": "concept_intro",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "左侧放置文字说明，右侧可放一个简洁的对比示意图（独热 vs 分布式）"
    },
    {
      "id": "vector_example",
      "type": "rounded_rect",
      "label": "示例向量 [0.2, 0.8, -0.3, ...]",
      "parent_section": "concept_intro",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "在文字右侧显示一个带阴影的圆角框，内部写一个示例向量（例如[0.2, 0.8, -0.3, 0.5, -0.1]），用等宽字体"
    },
    {
      "id": "scatter_plot_area",
      "type": "rect",
      "label": "语义空间散点图",
      "parent_section": "semantic_space",
      "color_key": "background",
      "importance": "primary",
      "size_hint": {
        "min_width": 600,
        "min_height": 300,
        "aspect_ratio": 2
      },
      "content_hint": "包含x/y坐标轴，刻度标签，多个彩色散点（词点）和半透明虚线聚类区域，词点旁标注词语如'国王','王后','男人','女人'等"
    },
    {
      "id": "x_axis",
      "type": "axis",
      "label": "PCA 维度1",
      "parent_section": "semantic_space",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 500,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "水平轴标签，带箭头"
    },
    {
      "id": "y_axis",
      "type": "axis",
      "label": "PCA 维度2",
      "parent_section": "semantic_space",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 20,
        "min_height": 280,
        "aspect_ratio": null
      },
      "content_hint": "垂直轴标签，带箭头"
    },
    {
      "id": "scatter_points",
      "type": "circle",
      "label": "",
      "parent_section": "semantic_space",
      "color_key": "palette[0]",
      "importance": "primary",
      "size_hint": {
        "min_width": 8,
        "min_height": 8,
        "aspect_ratio": 1
      },
      "content_hint": "多个彩色圆点，分别代表不同词语，颜色按语义类别编码（如国家、性别、物品）"
    },
    {
      "id": "cluster_region1",
      "type": "ellipse",
      "label": "性别相关",
      "parent_section": "semantic_space",
      "color_key": "palette[0]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "半透明虚线椭圆包围一组词点，内部可标注类别名称"
    },
    {
      "id": "cluster_region2",
      "type": "ellipse",
      "label": "国家首都",
      "parent_section": "semantic_space",
      "color_key": "palette[1]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 70,
        "aspect_ratio": null
      },
      "content_hint": "另一个半透明虚线椭圆包围另一组词点"
    },
    {
      "id": "analogy_diagram_area",
      "type": "rounded_rect",
      "label": "类比展示: king - man + woman = queen",
      "parent_section": "analogy_demo",
      "color_key": "background",
      "importance": "primary",
      "size_hint": {
        "min_width": 600,
        "min_height": 200,
        "aspect_ratio": 3
      },
      "content_hint": "包含四个词标签（king, man, woman, queen）和向量箭头，两个平行箭头展示语义关系迁移，底部显示公式"
    },
    {
      "id": "king_label",
      "type": "text_block",
      "label": "king",
      "parent_section": "analogy_demo",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 40,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "左上角位置"
    },
    {
      "id": "man_label",
      "type": "text_block",
      "label": "man",
      "parent_section": "analogy_demo",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 30,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "左下角位置"
    },
    {
      "id": "woman_label",
      "type": "text_block",
      "label": "woman",
      "parent_section": "analogy_demo",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 40,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "右下角位置"
    },
    {
      "id": "queen_label",
      "type": "text_block",
      "label": "queen",
      "parent_section": "analogy_demo",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 40,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "右上角位置"
    },
    {
      "id": "arrow_man_to_king",
      "type": "arrow",
      "label": "+royal",
      "parent_section": "analogy_demo",
      "color_key": "primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 4,
        "aspect_ratio": null
      },
      "content_hint": "从 man 指向 king 的箭头，中间标注 +royal"
    },
    {
      "id": "arrow_woman_to_queen",
      "type": "arrow",
      "label": "+royal",
      "parent_section": "analogy_demo",
      "color_key": "primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 4,
        "aspect_ratio": null
      },
      "content_hint": "从 woman 指向 queen 的箭头，与上一个箭头平行，同样标注 +royal"
    },
    {
      "id": "analogy_formula",
      "type": "text_block",
      "label": "king − man + woman ≈ queen",
      "parent_section": "analogy_demo",
      "color_key": "accent",
      "importance": "primary",
      "size_hint": {
        "min_width": 300,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "底部居中显示公式，使用较大字体和强调色"
    },
    {
      "id": "footer_text",
      "type": "text_block",
      "label": "注：概念图仅用于科普演示，实际词向量维度可达几百维。训练方法包括Word2Vec(CBOW/Skip-gram)和GloVe等。",
      "parent_section": "footer_notes",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 600,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "小字体，居中或靠左显示"
    }
  ],
  "connections": [
    {
      "id": "conn_man_king",
      "type": "arrow",
      "from_element": "man_label",
      "to_element": "king_label",
      "direction": "left-to-right",
      "label": "+royal",
      "line_style": "solid"
    },
    {
      "id": "conn_woman_queen",
      "type": "arrow",
      "from_element": "woman_label",
      "to_element": "queen_label",
      "direction": "left-to-right",
      "label": "+royal",
      "line_style": "solid"
    },
    {
      "id": "conn_concept_to_scatter",
      "type": "dashed",
      "from_element": "intro_text",
      "to_element": "scatter_plot_area",
      "direction": "top-to-bottom",
      "label": "降维可视化",
      "line_style": "dashed"
    },
    {
      "id": "conn_scatter_to_analogy",
      "type": "dashed",
      "from_element": "scatter_plot_area",
      "to_element": "analogy_diagram_area",
      "direction": "top-to-bottom",
      "label": "语义关系举例",
      "line_style": "dashed"
    }
  ],
  "design_notes": "整体采用柔和蓝紫渐变背景，各内容区使用轻微圆角和阴影增加层次感。标题区字体加粗，使用渐变色标题（#6C63FF到#9B8EFF）。概念介绍段的对比示意图用两个并排的矩形（一个高瘦代表独热编码，一个矮胖代表分布式表示）突出差异。语义空间散点图使用明亮对比色（palette中的颜色），聚类边界用虚线半透明椭圆，词标签用小号无衬线字体。类比展示中的向量箭头使用1.5倍细线，标注文字使用accent色。整体留白充足，确保阅读舒适。"
}