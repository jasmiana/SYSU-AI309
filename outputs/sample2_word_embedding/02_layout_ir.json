{
  "chart_type": "concept_map",
  "canvas": {
    "width": 800,
    "height": 1000,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "科技蓝紫",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#FF6B6B",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#27AE60",
      "#F39C12",
      "#E74C3C"
    ],
    "rationale": "科技蓝紫配色方案符合技术概念主题，蓝紫渐变传递智能与创新感，高对比度的文字确保可读性，辅助色用于区分不同子概念。"
  },
  "typography": {
    "title_size": 36,
    "heading_size": 22,
    "body_size": 15,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 12,
    "rows": 6,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "主标题区域，显示词向量主题"
    },
    {
      "id": "diagram_section",
      "type": "diagram",
      "position": {
        "x_pct": 0,
        "y_pct": 10,
        "width_pct": 100,
        "height_pct": 80
      },
      "visual_weight": "primary",
      "purpose": "概念图核心区域，以放射状结构展示词向量的定义、特性、方法、类比运算与应用"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 0,
        "y_pct": 90,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "tertiary",
      "purpose": "脚注或总结性语句区域"
    }
  ],
  "elements": [
    {
      "id": "main_title",
      "type": "text_block",
      "label": "词向量：让计算机理解词语的意义",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "主标题大字，居中显示，使用标题字号和加粗"
    },
    {
      "id": "center_node",
      "type": "circle",
      "label": "词向量",
      "parent_section": "diagram_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 120,
        "min_height": 120,
        "aspect_ratio": 1
      },
      "content_hint": "中心概念节点，使用主色填充，放置于图区视觉中心略偏上"
    },
    {
      "id": "node_definition",
      "type": "rounded_rect",
      "label": "语义映射\n词语 → 实数向量",
      "parent_section": "diagram_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "解释词向量定义的子节点，位于中心节点上方"
    },
    {
      "id": "node_similarity",
      "type": "rounded_rect",
      "label": "语义相似性\n空间距离近",
      "parent_section": "diagram_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "说明语义相似性的子节点，位于中心节点右上方"
    },
    {
      "id": "node_methods",
      "type": "rounded_rect",
      "label": "训练方法\nWord2Vec & GloVe",
      "parent_section": "diagram_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "介绍生成方法的子节点，位于中心节点右侧"
    },
    {
      "id": "node_analogy",
      "type": "rounded_rect",
      "label": "类比运算\n国王-男人+女人≈王后",
      "parent_section": "diagram_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "展示算术运算特性的子节点，位于中心节点右下方"
    },
    {
      "id": "node_applications",
      "type": "rounded_rect",
      "label": "应用场景\n翻译、情感分析、问答",
      "parent_section": "diagram_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "列举应用的子节点，位于中心节点下方"
    },
    {
      "id": "footer_text",
      "type": "text_block",
      "label": "词向量技术是自然语言处理的基础，让机器理解语言的内涵。",
      "parent_section": "footer_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 600,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "脚注总结文本，水平居中，字号较小"
    }
  ],
  "connections": [
    {
      "id": "conn_definition",
      "type": "arrow",
      "from_element": "center_node",
      "to_element": "node_definition",
      "direction": "radial",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn_similarity",
      "type": "arrow",
      "from_element": "center_node",
      "to_element": "node_similarity",
      "direction": "radial",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn_methods",
      "type": "arrow",
      "from_element": "center_node",
      "to_element": "node_methods",
      "direction": "radial",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn_analogy",
      "type": "arrow",
      "from_element": "center_node",
      "to_element": "node_analogy",
      "direction": "radial",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn_applications",
      "type": "arrow",
      "from_element": "center_node",
      "to_element": "node_applications",
      "direction": "radial",
      "label": null,
      "line_style": "solid"
    }
  ],
  "design_notes": "采用放射状概念图设计，中心为显著加大的圆形节点'词向量'，使用主色填充并加阴影突出其核心地位。五个围绕的圆角矩形子节点均匀分布在四周，使用辅色填充，分别解释定义、相似性、方法、类比运算与应用。各子节点与中心节点用实线箭头连接，方向呈放射状向外，箭头清晰指示概念展开关系。标题位于顶部居中，以超大号深色粗体文字展示；底部脚注以浅灰色小字居中总结。整体背景为浅蓝白，留白充足，网格对齐，视觉层次分明，阅读顺序从标题到中心再到周围节点，最后落脚脚注。"
}