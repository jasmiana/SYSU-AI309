  "color_scheme": {
    "name": "科技蓝紫",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#FF6B6B",
    "background": "#F5F7FA",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#FF6B6B",
      "#50C878",
      "#F4A261",
      "#9B59B6"
    ],
    "rationale": "选择蓝色为主色调，因为词向量是AI/自然语言处理的核心技术，蓝色传递冷静、理性的科技感，适合科普内容。紫色作为辅助色与蓝色形成类比关系，产生和谐统一的视觉效果，用于对比独热编码。珊瑚红强调色用于突出类比操作中的关键结果(queen)，吸引视觉焦点。整体配色柔和，避免过于鲜艳，适合大众阅读。标题栏使用水平渐变从左到右从蓝到紫，模拟向量空间的方向感，增强层次。"
  },
