      },
      "content_hint": "子节点，与 info_3 呼应"
    },
    {
      "id": "node_application",
      "type": "rounded_rect",
      "label": "NLP应用",
      "parent_section": "diagram_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 130,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "子节点，与 info_4 呼应"
    },
    {
      "id": "text_info_1",
      "type": "text_block",
      "label": "什么是词向量？",
      "parent_section": "info_1",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 300,
        "min_height": 100,
        "aspect_ratio": null
      },
      "content_hint": "详细解释：词向量是将词语表示为连续、低维、稠密的实数向量，解决了独热编码维度过高且无语义的问题。"
    },
    {
      "id": "text_info_2",
      "type": "text_block",
      "label": "语义相似性",
      "parent_section": "info_2",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 300,
        "min_height": 100,
        "aspect_ratio": null
      },
      "content_hint": "详细解释：通过训练神经网络语言模型（如Word2Vec、GloVe）获得，使得语义相似的词在向量空间中距离更近。"
    },
    {
      "id": "text_info_3",
      "type": "text_block",
      "label": "类比推理能力",
      "parent_section": "info_3",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 300,
        "min_height": 100,
        "aspect_ratio": null
      },
      "content_hint": "详细解释：词向量运算能捕捉语义关系，例如：国王 - 男人 + 女人 ≈ 王后，体现了类比推理特性。"
    },
    {
      "id": "text_info_4",
      "type": "text_block",
      "label": "应用领域",
      "parent_section": "info_4",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 300,
        "min_height": 100,
        "aspect_ratio": null
      },
      "content_hint": "详细解释：作为NLP基础，广泛应用于文本分类、机器翻译、情感分析等任务，让计算机更好地理解语言。"
    },
    {
      "id": "footer_text",
      "type": "text_block",
      "label": "来源：词向量技术科普",
      "parent_section": "footer_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 200,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "显示脚注或参考信息，小号灰色字"
    }
  ],
