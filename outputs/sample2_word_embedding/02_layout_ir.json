{
  "chart_type": "concept_map",
  "canvas": {
    "width": 800,
    "height": 1100,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "科技蓝紫",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#FF6B6B",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#5DADE2",
      "#8E44AD"
    ],
    "rationale": "技术概念图适合使用冷静专业的蓝紫色系，传递科技与智能感，背景浅色确保可读性。"
  },
  "typography": {
