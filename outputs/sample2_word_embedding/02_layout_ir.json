      "size_hint": {
        "min_width": 8,
        "min_height": 250,
        "aspect_ratio": null
      },
      "content_hint": "纵轴，标注主成分2"
    },
    {
      "id": "cluster_region_fruit",
      "type": "ellipse",
      "label": "水果",
      "parent_section": "middle_section",
      "color_key": "secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 100,
        "min_height": 80,
