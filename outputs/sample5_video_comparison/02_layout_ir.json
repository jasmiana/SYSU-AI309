{
  "chart_type": "bar_chart",
  "canvas": {
    "width": 800,
    "height": 1000,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "数据可视化",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#27AE60",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#27AE60",
      "#F39C12",
      "#E74C3C"
    ],
    "rationale": "三个平台的对比需要鲜明且区分度高的颜色，多色板能直观区分实体并保持科技感，同时蓝色代表YouTube的庞大，紫色代表TikTok的潮流，绿色代表快手的本土化。"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 22,
    "body_size": 16,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 3,
    "rows": null,
    "gutter": 30
  },
  "sections": [
    {
      "id": "title-section",
      "type": "title",
      "position": {
        "x_pct": 5.0,
        "y_pct": 2.0,
        "width_pct": 90.0,
        "height_pct": 10.0
      },
      "visual_weight": "primary",
      "purpose": "展示主标题，吸引注意力"
    },
    {
      "id": "chart-section",
      "type": "chart",
      "position": {
        "x_pct": 10.0,
        "y_pct": 14.0,
        "width_pct": 80.0,
        "height_pct": 52.0
      },
      "visual_weight": "primary",
      "purpose": "核心条形图，展示三个平台视频数量的对比关系"
    },
    {
      "id": "insight-section",
      "type": "content_block",
      "position": {
        "x_pct": 10.0,
        "y_pct": 70.0,
        "width_pct": 80.0,
        "height_pct": 22.0
      },
      "visual_weight": "secondary",
      "purpose": "提炼关键数据洞察，辅助读者理解图表"
    },
    {
      "id": "footer-section",
      "type": "footer",
      "position": {
        "x_pct": 5.0,
        "y_pct": 94.0,
        "width_pct": 90.0,
        "height_pct": 5.0
      },
      "visual_weight": "tertiary",
      "purpose": "显示数据来源或脚注"
    }
  ],
  "elements": [
    {
      "id": "main-title",
      "type": "text_block",
      "label": "YouTube vs TikTok vs Kuaishou: Video Count Comparison",
      "parent_section": "title-section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 600,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "展示完整主标题，两行英文，加粗居中"
    },
    {
      "id": "axis-x",
      "type": "axis",
      "label": "",
      "parent_section": "chart-section",
      "color_key": "text_secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 0,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "X轴，标注三个平台名称：Kuaishou, TikTok, YouTube"
    },
    {
      "id": "axis-y",
      "type": "axis",
      "label": "Relative Video Count",
      "parent_section": "chart-section",
      "color_key": "text_secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 50,
        "min_height": 0,
        "aspect_ratio": null
      },
      "content_hint": "Y轴，使用简化的单位或不显示具体数值，仅展现比例关系"
    },
    {
      "id": "bar-youtube",
      "type": "rect",
      "label": "YouTube",
      "parent_section": "chart-section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 400,
        "aspect_ratio": null
      },
      "content_hint": "柱子高度对应YouTube视频数量，为TikTok的10倍，需要标注数值或倍数"
    },
    {
      "id": "bar-tiktok",
      "type": "rect",
      "label": "TikTok",
      "parent_section": "chart-section",
      "color_key": "secondary",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "柱子高度对应TikTok视频数量，为快手的2倍"
    },
    {
      "id": "bar-kuaishou",
      "type": "rect",
      "label": "Kuaishou",
      "parent_section": "chart-section",
      "color_key": "accent",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "柱子高度对应快手视频数量，数值最小"
    },
    {
      "id": "label-youtube",
      "type": "text_block",
      "label": "10× more\nthan TikTok",
      "parent_section": "chart-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "放置在YouTube柱子附近，强调倍数关系"
    },
    {
      "id": "label-tiktok",
      "type": "text_block",
      "label": "2× more\nthan Kuaishou",
      "parent_section": "chart-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "放置在TikTok柱子附近"
    },
    {
      "id": "insight-text",
      "type": "text_block",
      "label": "• YouTube dominates with 10× the video library of TikTok\n• TikTok still holds 2× the content volume of Kuaishou\n• The supply gap reveals YouTube’s long-tail content advantage",
      "parent_section": "insight-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 500,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "展示三个核心洞察要点，使用项目符号列表"
    },
    {
      "id": "footer-note",
      "type": "text_block",
      "label": "Data based on public estimates, 2025",
      "parent_section": "footer-section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 200,
        "min_height": 15,
        "aspect_ratio": null
      },
      "content_hint": "脚注，展示数据来源和年份"
    }
  ],
  "connections": [
    {
      "id": "conn-yt-tt",
      "type": "curve",
      "from_element": "bar-tiktok",
      "to_element": "bar-youtube",
      "direction": "left-to-right",
      "label": "10× more",
      "line_style": "dashed"
    },
    {
      "id": "conn-tt-ks",
      "type": "curve",
      "from_element": "bar-kuaishou",
      "to_element": "bar-tiktok",
      "direction": "left-to-right",
      "label": "2× more",
      "line_style": "dashed"
    }
  ],
  "design_notes": "采用简洁现代的扁平化风格，背景为浅蓝灰色，标题居中加粗。条形图区三个柱子从左到右依次为Kuaishou、TikTok、YouTube，高度表达相对规模（YouTube: 400px, TikTok: 40px, Kuaishou: 20px）。Y轴隐藏或淡化刻度，突出高度差异。两条虚线曲线连接柱顶，直接标注倍数关系，视觉上将对比逻辑具象化。左侧添加清晰的平台logo占位或首字母图标辅助识别。洞察文本置于图表下方，使用圆点列表，字体略小于标题。整体颜色柔和但柱子颜色鲜明，确保10倍差距一目了然。留白充裕，元素间不少于20px间距，所有文本使用系统无衬线字体以保证多语言可读性。"
}