{
  "chart_type": "comparison_chart",
  "canvas": {
    "width": 800,
    "height": 900,
    "background": "#FFFFFF"
  },
  "color_scheme": {
    "name": "冷静数据对比",
    "primary": "#1976D2",
    "secondary": "#FF9800",
    "accent": "#4CAF50",
    "background": "#FFFFFF",
    "text_primary": "#212121",
    "text_secondary": "#757575",
    "palette": [
      "#1976D2",
      "#FF9800",
      "#4CAF50",
      "#9C27B0"
    ],
    "rationale": "蓝色主调传达数据对比的冷静与可靠，橙色作为对比突出TikTok的中等位置，绿色用于最小平台快手，形成色彩阶梯，直观反映数量层级。标题栏使用水平蓝色渐变，从左到右引导阅读顺序，强化开阔感。"
  },
  "typography": {
    "title_size": 28,
    "heading_size": 20,
    "body_size": 14,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 12,
    "rows": 12,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title-section",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示主标题，吸引注意力"
    },
    {
      "id": "chart-section",
      "type": "diagram",
      "position": {
        "x_pct": 5,
        "y_pct": 10,
        "width_pct": 90,
        "height_pct": 75
      },
      "visual_weight": "primary",
      "purpose": "展示三大平台视频数量的柱状对比图及倍数关系"
    },
    {
      "id": "footer-section",
      "type": "footer",
      "position": {
        "x_pct": 5,
        "y_pct": 85,
        "width_pct": 90,
        "height_pct": 10
      },
      "visual_weight": "tertiary",
      "purpose": "注释说明，帮助理解数据含义"
    }
  ],
  "elements": [
    {
      "id": "youtube-bar",
      "type": "rounded_rect",
      "label": "",
      "parent_section": "chart-section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 540,
        "aspect_ratio": null
      },
      "content_hint": "柱体填充蓝色，高度代表YouTube相对数量（10单位）"
    },
    {
      "id": "tiktok-bar",
      "type": "rounded_rect",
      "label": "",
      "parent_section": "chart-section",
      "color_key": "secondary",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 54,
        "aspect_ratio": null
      },
      "content_hint": "柱体填充橙色，高度代表TikTok相对数量（1单位）"
    },
    {
      "id": "kuaishou-bar",
      "type": "rounded_rect",
      "label": "",
      "parent_section": "chart-section",
      "color_key": "accent",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 27,
        "aspect_ratio": null
      },
      "content_hint": "柱体填充绿色，高度代表Kuaishou相对数量（0.5单位）"
    },
    {
      "id": "youtube-label",
      "type": "text_block",
      "label": "YouTube",
      "parent_section": "chart-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 60,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "平台名称，位于蓝色柱体下方"
    },
    {
      "id": "tiktok-label",
      "type": "text_block",
      "label": "TikTok",
      "parent_section": "chart-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 60,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "平台名称，位于橙色柱体下方"
    },
    {
      "id": "kuaishou-label",
      "type": "text_block",
      "label": "Kuaishou",
      "parent_section": "chart-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 60,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "平台名称，位于绿色柱体下方"
    },
    {
      "id": "youtube-value-label",
      "type": "text_block",
      "label": "10",
      "parent_section": "chart-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 20,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "相对数量值，位于蓝色柱体顶部上方"
    },
    {
      "id": "tiktok-value-label",
      "type": "text_block",
      "label": "1",
      "parent_section": "chart-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 20,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "相对数量值，位于橙色柱体顶部上方"
    },
    {
      "id": "kuaishou-value-label",
      "type": "text_block",
      "label": "0.5",
      "parent_section": "chart-section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 20,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "相对数量值，位于绿色柱体顶部上方"
    },
    {
      "id": "footer-text",
      "type": "text_block",
      "label": "注：数据为相对比例，仅用于展示倍数差异。",
      "parent_section": "footer-section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 200,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "注释文本，居中显示"
    }
  ],
  "connections": [
    {
      "id": "conn-youtube-tiktok",
      "type": "curve",
      "from_element": "youtube-bar",
      "to_element": "tiktok-bar",
      "direction": "left-to-right",
      "label": "10x",
      "line_style": "solid"
    },
    {
      "id": "conn-tiktok-kuaishou",
      "type": "curve",
      "from_element": "tiktok-bar",
      "to_element": "kuaishou-bar",
      "direction": "left-to-right",
      "label": "2x",
      "line_style": "solid"
    }
  ],
  "design_notes": "采用直立柱状图对比三大平台视频数量，用蓝、橙、绿三色区分YouTube、TikTok、Kuaishou，柱顶标注相对数值（10、1、0.5），柱间用红色曲线箭头标注倍数关系（10x和2x），以突出巨大差异。标题栏使用水平蓝色渐变（#1976D2到#BBDEFB），营造开阔感。整体风格现代、清晰、重点突出，底色纯白保持简洁。"
}