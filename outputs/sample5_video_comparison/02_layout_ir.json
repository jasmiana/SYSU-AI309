{
  "chart_type": "horizontal_bar_chart",
  "canvas": {
    "width": 800,
    "height": 1000,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "数据可视化",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#27AE60",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#27AE60",
      "#F39C12",
      "#E74C3C"
    ],
    "rationale": "使用高区分度多色方案，蓝色（YouTube）强调绝对优势，紫色（TikTok）为中间量，绿色（快手）作为基准，符合科技平台对比的现代感。"
  },
  "typography": {
    "title_size": 30,
    "heading_size": 22,
    "body_size": 16,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', -apple-system, sans-serif"
  },
  "layout_grid": {
    "columns": 1,
    "rows": 3,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示图表主标题，吸引读者注意"
    },
    {
      "id": "chart_section",
      "type": "chart",
      "position": {
        "x_pct": 5,
        "y_pct": 10,
        "width_pct": 90,
        "height_pct": 80
      },
      "visual_weight": "primary",
      "purpose": "核心数据对比区，水平条形图展示三平台视频数量倍数关系"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 5,
        "y_pct": 90,
        "width_pct": 90,
        "height_pct": 10
      },
      "visual_weight": "tertiary",
      "purpose": "数据来源与单位说明，基准注释"
    }
  ],
  "elements": [
    {
      "id": "main_title",
      "type": "text_block",
      "label": "YouTube、TikTok与快手视频数量对比",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "主标题，居中放置，使用 title_size (30px) Bold"
    },
    {
      "id": "axis_y",
      "type": "line",
      "label": "",
      "parent_section": "chart_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 2,
        "min_height": 300,
        "aspect_ratio": null
      },
      "content_hint": "类别轴（Y轴），位于图表左侧，标注平台名称"
    },
    {
      "id": "axis_x",
      "type": "line",
      "label": "",
      "parent_section": "chart_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 400,
        "min_height": 2,
        "aspect_ratio": null
      },
      "content_hint": "数值轴（X轴），位于图表底部，刻度从0到25（以快手=1）"
    },
    {
      "id": "bar_youtube",
      "type": "rect",
      "label": "YouTube (20x)",
      "parent_section": "chart_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 300,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "YouTube条形，宽度按比例占据X轴20单位长度（占总条宽80%），颜色 primary #4A90D9，高度30px，左侧对齐Y轴标签"
    },
    {
      "id": "bar_tiktok",
      "type": "rect",
      "label": "TikTok (2x)",
      "parent_section": "chart_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 40,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "TikTok条形，宽度2单位（占总条宽8%），颜色 secondary #7B68EE"
    },
    {
      "id": "bar_kuaishou",
      "type": "rect",
      "label": "快手 (1x)",
      "parent_section": "chart_section",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 20,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "快手基准条形，宽度1单位（占总条宽4%），颜色 accent #27AE60"
    },
    {
      "id": "label_youtube",
      "type": "text_block",
      "label": "20×",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 50,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "YouTube条形末端标签，标注20倍，使用 label_size Medium"
    },
    {
      "id": "label_tiktok",
      "type": "text_block",
      "label": "2×",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 30,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "TikTok条形末端标签，标注2倍"
    },
    {
      "id": "label_kuaishou",
      "type": "text_block",
      "label": "1× (基准)",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 50,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "快手条形末端标签，标注1倍基准"
    },
    {
      "id": "comparison_arrow_10x",
      "type": "line",
      "label": "10倍",
      "parent_section": "chart_section",
      "color_key": "accent",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 100,
        "min_height": 1,
        "aspect_ratio": null
      },
      "content_hint": "从TikTok条形末端（2单位处）延伸到YouTube条形的比较线，虚线，带箭头，上方标注'10倍'"
    },
    {
      "id": "comparison_arrow_2x",
      "type": "line",
      "label": "2倍",
      "parent_section": "chart_section",
      "color_key": "accent",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 40,
        "min_height": 1,
        "aspect_ratio": null
      },
      "content_hint": "从快手条形末端（1单位处）到TikTok条形的比较线，虚线箭头，标注'2倍'"
    },
    {
      "id": "comparison_arrow_20x",
      "type": "line",
      "label": "20倍（推断）",
      "parent_section": "chart_section",
      "color_key": "accent",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 140,
        "min_height": 1,
        "aspect_ratio": null
      },
      "content_hint": "从快手末端到YouTube条形的跨线比较，用不同样式的虚线或括号，标注'20倍（推断）'"
    },
    {
      "id": "legend",
      "type": "rect",
      "label": "",
      "parent_section": "chart_section",
      "color_key": "background",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 150,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "图例区域，包含三个色块和平台名称：蓝色YouTube、紫色TikTok、绿色快手"
    },
    {
      "id": "footer_text",
      "type": "text_block",
      "label": "* 以快手视频数量为基准（1x），数据基于用户提供倍数关系推算",
      "parent_section": "footer_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 400,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "脚注说明文字，使用 label_size，颜色 text_secondary"
    }
  ],
  "connections": [
    {
      "id": "conn_10x",
      "type": "dashed",
      "from_element": "bar_tiktok",
      "to_element": "bar_youtube",
      "direction": "left-to-right",
      "label": "10倍",
      "line_style": "dashed"
    },
    {
      "id": "conn_2x",
      "type": "dashed",
      "from_element": "bar_kuaishou",
      "to_element": "bar_tiktok",
      "direction": "left-to-right",
      "label": "2倍",
      "line_style": "dashed"
    },
    {
      "id": "conn_20x",
      "type": "dashed",
      "from_element": "bar_kuaishou",
      "to_element": "bar_youtube",
      "direction": "left-to-right",
      "label": "20倍 (推断)",
      "line_style": "dotted"
    }
  ],
  "design_notes": "整体采用干净的数据看板风格，浅蓝白背景。主标题醒目置于顶部居中。水平条形图纵轴依次排列快手、TikTok、YouTube，横轴为相对视频数量。条形宽度严格按比例（1:2:20），并用品牌色彩区分。条形末端直接标注倍数，避免猜测。在条形之间使用虚线箭头连接，清晰展示10倍和2倍的直接对比，并加一条从快手指向YouTube的虚线点线表示推断的20倍关系，使倍数逻辑一目了然。图例放置在右上角或下方，保持视觉平衡。所有文字使用系统无衬线字体，保证跨平台清晰度。留白充裕，使比较关系突出，无压抑感。"
}