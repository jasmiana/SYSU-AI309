{
  "chart_type": "comparison_chart",
  "canvas": {
    "width": 800,
    "height": 900,
    "background": "#FFFFFF"
  },
  "color_scheme": {
    "name": "数据可视化多色板",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#27AE60",
    "background": "#FFFFFF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#27AE60"
    ],
    "rationale": "采用明亮区分度高的多色板，三个平台各分配一种颜色，便于快速识别对比"
  },
  "typography": {
    "title_size": 28,
    "heading_size": 20,
    "body_size": 14,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 1,
    "rows": 3,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 9
      },
      "visual_weight": "primary",
      "purpose": "展示主标题，吸引注意"
    },
    {
      "id": "chart_area",
      "type": "chart",
      "position": {
        "x_pct": 5,
        "y_pct": 11,
        "width_pct": 90,
        "height_pct": 78
      },
      "visual_weight": "primary",
      "purpose": "承载柱状图、坐标轴、数据标签和说明文字"
    },
    {
      "id": "footnote",
      "type": "footer",
      "position": {
        "x_pct": 0,
        "y_pct": 92,
        "width_pct": 100,
        "height_pct": 8
      },
      "visual_weight": "tertiary",
      "purpose": "放置数据来源脚注"
    }
  ],
  "elements": [
    {
      "id": "title_text",
      "type": "text_block",
      "label": "短视频平台视频数量对比",
      "parent_section": "title",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "主标题，居中显示"
    },
    {
      "id": "y_axis",
      "type": "axis",
      "label": "相对视频数量（单位）",
      "parent_section": "chart_area",
      "color_key": "text_secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 40,
        "min_height": 200,
        "aspect_ratio": 0.2
      },
      "content_hint": "纵坐标轴，刻度从0到10，标明单位"
    },
    {
      "id": "x_axis",
      "type": "axis",
      "label": "",
      "parent_section": "chart_area",
      "color_key": "text_secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 400,
        "min_height": 30,
        "aspect_ratio": 13.33
      },
      "content_hint": "横坐标轴，下方标注三个平台名称"
    },
    {
      "id": "bar_youtube",
      "type": "bar",
      "label": "YouTube",
      "parent_section": "chart_area",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 60,
        "min_height": 200,
        "aspect_ratio": 0.3
      },
      "content_hint": "柱高代表10单位，顶部标注'10x'或'是TikTok的10倍'"
    },
    {
      "id": "bar_tiktok",
      "type": "bar",
      "label": "TikTok",
      "parent_section": "chart_area",
      "color_key": "secondary",
      "importance": "primary",
      "size_hint": {
        "min_width": 60,
        "min_height": 100,
        "aspect_ratio": 0.6
      },
      "content_hint": "柱高代表1单位（相对），顶部标注'1'"
    },
    {
      "id": "bar_kuaishou",
      "type": "bar",
      "label": "Kuaishou",
      "parent_section": "chart_area",
      "color_key": "accent",
      "importance": "primary",
      "size_hint": {
        "min_width": 60,
        "min_height": 50,
        "aspect_ratio": 1.2
      },
      "content_hint": "柱高代表0.5单位，顶部标注'0.5'"
    },
    {
      "id": "data_label_youtube",
      "type": "text_block",
      "label": "10× TikTok",
      "parent_section": "chart_area",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 20,
        "aspect_ratio": 4
      },
      "content_hint": "在YouTube柱顶显示'10× TikTok'"
    },
    {
      "id": "data_label_tiktok",
      "type": "text_block",
      "label": "2× Kuaishou",
      "parent_section": "chart_area",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 20,
        "aspect_ratio": 4
      },
      "content_hint": "在TikTok柱顶显示'2× Kuaishou'"
    },
    {
      "id": "comparison_note",
      "type": "text_block",
      "label": "YouTube视频数量是TikTok的10倍，TikTok是Kuaishou的2倍",
      "parent_section": "chart_area",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 400,
        "min_height": 30,
        "aspect_ratio": 13.33
      },
      "content_hint": "在图表下方或侧边放置说明文字，概括倍数关系"
    },
    {
      "id": "footnote_text",
      "type": "text_block",
      "label": "数据基于公开估算，实际数值可能有所浮动",
      "parent_section": "footnote",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 400,
        "min_height": 20,
        "aspect_ratio": 20
      },
      "content_hint": "脚注，左对齐或居中显示"
    }
  ],
  "connections": [],
  "design_notes": "整体采用简洁明快的卡片式布局，三个柱子宽度一致、颜色鲜明区分，柱顶数据标签突出倍数关系。坐标轴刻度清晰，图表区域留有足够内边距。标题大号加粗，脚注浅色小字。确保信息一目了然。"
}