{
  "chart_type": "bar_chart",
  "canvas": {
    "width": 800,
    "height": 900,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "数据可视化",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#FF6B6B",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#27AE60",
      "#F39C12",
      "#E74C3C"
    ],
    "rationale": "数据对比图需要清晰区分不同实体，使用明亮且对比度高的颜色，YouTube为主色蓝色，TikTok为紫色，Kuaishou为绿色，突出数量差异。"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 20,
    "body_size": 15,
    "label_size": 14,
    "font_family": "system-ui, -apple-system, sans-serif"
  },
  "layout_grid": {
    "columns": 24,
    "rows": 12,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 5,
        "y_pct": 2,
        "width_pct": 90,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示主标题，吸引视觉焦点"
    },
    {
      "id": "chart_section",
      "type": "diagram",
      "position": {
        "x_pct": 10,
        "y_pct": 15,
        "width_pct": 80,
        "height_pct": 70
      },
      "visual_weight": "primary",
      "purpose": "核心数据对比区，包含柱状图和倍数标注"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 5,
        "y_pct": 87,
        "width_pct": 90,
        "height_pct": 10
      },
      "visual_weight": "tertiary",
      "purpose": "数据说明和来源注释"
    }
  ],
  "elements": [
    {
      "id": "main_title",
      "type": "text_block",
      "label": "Video Quantity Comparison: YouTube vs TikTok vs Kuaishou",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 600,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "主标题，使用大号粗体字，居中放置"
    },
    {
      "id": "bar_youtube",
      "type": "rounded_rect",
      "label": "YouTube (20x)",
      "parent_section": "chart_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 120,
        "min_height": 500,
        "aspect_ratio": null
      },
      "content_hint": "YouTube 柱子，相对高度为 20 单位，柱顶标注 '20x'"
    },
    {
      "id": "bar_tiktok",
      "type": "rounded_rect",
      "label": "TikTok (2x)",
      "parent_section": "chart_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "TikTok 柱子，相对高度为 2 单位，柱顶标注 '2x'"
    },
    {
      "id": "bar_kuaishou",
      "type": "rounded_rect",
      "label": "Kuaishou (1x)",
      "parent_section": "chart_section",
      "color_key": "palette[2]",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 80,
        "min_height": 25,
        "aspect_ratio": null
      },
      "content_hint": "Kuaishou 柱子，相对高度为 1 单位，柱顶标注 '1x'"
    },
    {
      "id": "y_axis",
      "type": "line",
      "label": null,
      "parent_section": "chart_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 0,
        "min_height": 550,
        "aspect_ratio": null
      },
      "content_hint": "左侧垂直轴线，表示相对视频数量"
    },
    {
      "id": "x_axis",
      "type": "line",
      "label": null,
      "parent_section": "chart_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 500,
        "min_height": 0,
        "aspect_ratio": null
      },
      "content_hint": "底部水平轴线，用于放置平台名称标签"
    },
    {
      "id": "label_youtube",
      "type": "text_block",
      "label": "YouTube",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 120,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "YouTube 柱底标签"
    },
    {
      "id": "label_tiktok",
      "type": "text_block",
      "label": "TikTok",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "TikTok 柱底标签"
    },
    {
      "id": "label_kuaishou",
      "type": "text_block",
      "label": "Kuaishou",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 80,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "Kuaishou 柱底标签"
    },
    {
      "id": "note_text",
      "type": "text_block",
      "label": "Comparison based on relative multiplier values (Kuaishou = 1 unit)",
      "parent_section": "footer_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 400,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "脚注说明，小字，居中"
    }
  ],
  "connections": [
    {
      "id": "conn_yt_tk",
      "type": "arrow",
      "from_element": "bar_tiktok",
      "to_element": "bar_youtube",
      "direction": "bottom-to-top",
      "label": "10x",
      "line_style": "solid"
    },
    {
      "id": "conn_tk_ks",
      "type": "arrow",
      "from_element": "bar_kuaishou",
      "to_element": "bar_tiktok",
      "direction": "bottom-to-top",
      "label": "2x",
      "line_style": "solid"
    },
    {
      "id": "conn_yt_ks",
      "type": "arrow",
      "from_element": "bar_kuaishou",
      "to_element": "bar_youtube",
      "direction": "bottom-to-top",
      "label": "20x",
      "line_style": "dashed"
    }
  ],
  "design_notes": "采用垂直柱状图，三个柱子从左到右依次为 Kuaishou (1x), TikTok (2x), YouTube (20x)，高度按比例缩放。X轴为类别轴，Y轴不标注具体数字但保留垂直线。柱顶直接标注相对倍数，同时使用不同颜色的箭头连接柱子，清晰显示倍数关系。整体风格简洁现代，背景浅色，柱子使用微圆角，增加亲和力。标题使用加粗字体，脚注说明单位。确保所有元素有足够留白，柱子间距均匀，箭头线不与柱体重叠，箭头颜色与连接的起始柱体颜色一致以增强可读性。"
}