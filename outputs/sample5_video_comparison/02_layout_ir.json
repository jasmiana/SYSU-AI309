{
  "chart_type": "horizontal_bar_chart",
  "canvas": {
    "width": 800,
    "height": 1100,
    "background": "#FFFFFF"
  },
  "color_scheme": {
    "name": "brand_palette",
    "primary": "#E74C3C",
    "secondary": "#4A90D9",
    "accent": "#27AE60",
    "background": "#FFFFFF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#E74C3C",
      "#4A90D9",
      "#27AE60"
    ],
    "rationale": "使用与平台品牌色相关的配色：YouTube红、TikTok蓝、Kuaishou绿，便于识别和对比。"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 20,
    "body_size": 14,
    "label_size": 12,
    "font_family": "system-ui, -apple-system, sans-serif"
  },
  "layout_grid": {
    "columns": 12,
    "rows": 12,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "Display the main chart title"
    },
    {
      "id": "chart_section",
      "type": "diagram",
      "position": {
        "x_pct": 0,
        "y_pct": 10,
        "width_pct": 100,
        "height_pct": 80
      },
      "visual_weight": "primary",
      "purpose": "Horizontal bar chart comparing video counts among three platforms"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 0,
        "y_pct": 90,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "tertiary",
      "purpose": "Footnotes and source information"
    }
  ],
  "elements": [
    {
      "id": "title_text",
      "type": "text_block",
      "label": "视频平台视频数量对比：YouTube vs TikTok vs Kuaishou",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "Main title, centered horizontally and vertically within the section"
    },
    {
      "id": "label_youtube",
      "type": "text_block",
      "label": "YouTube",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Platform name, right-aligned within its area"
    },
    {
      "id": "bar_youtube",
      "type": "rect",
      "label": "",
      "parent_section": "chart_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Horizontal bar representing relative video count (20x). Fill with primary color (#E74C3C)."
    },
    {
      "id": "value_youtube",
      "type": "text_block",
      "label": "20x",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 40,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Relative count label, positioned at the end of the bar"
    },
    {
      "id": "label_tiktok",
      "type": "text_block",
      "label": "TikTok",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Platform name, right-aligned within its area"
    },
    {
      "id": "bar_tiktok",
      "type": "rect",
      "label": "",
      "parent_section": "chart_section",
      "color_key": "secondary",
      "importance": "primary",
      "size_hint": {
        "min_width": 60,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Horizontal bar representing relative video count (2x). Fill with secondary color (#4A90D9)."
    },
    {
      "id": "value_tiktok",
      "type": "text_block",
      "label": "2x",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 40,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Relative count label, positioned at the end of the bar"
    },
    {
      "id": "label_kuaishou",
      "type": "text_block",
      "label": "Kuaishou",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 80,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Platform name, right-aligned within its area"
    },
    {
      "id": "bar_kuaishou",
      "type": "rect",
      "label": "",
      "parent_section": "chart_section",
      "color_key": "accent",
      "importance": "primary",
      "size_hint": {
        "min_width": 30,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Horizontal bar representing relative video count (1x). Fill with accent color (#27AE60)."
    },
    {
      "id": "value_kuaishou",
      "type": "text_block",
      "label": "1x",
      "parent_section": "chart_section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 40,
        "min_height": 24,
        "aspect_ratio": null
      },
      "content_hint": "Relative count label, positioned at the end of the bar"
    },
    {
      "id": "x_axis_label",
      "type": "text_block",
      "label": "Relative Video Count (x times)",
      "parent_section": "chart_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 200,
        "min_height": 20,
        "aspect_ratio": null
      },
      "content_hint": "X-axis label, centered below the bars"
    }
  ],
  "connections": [
    {
      "id": "conn_yt_tt",
      "type": "arrow",
      "from_element": "bar_youtube",
      "to_element": "bar_tiktok",
      "direction": "top-to-bottom",
      "label": "10 times",
      "line_style": "dashed"
    },
    {
      "id": "conn_tt_ks",
      "type": "arrow",
      "from_element": "bar_tiktok",
      "to_element": "bar_kuaishou",
      "direction": "top-to-bottom",
      "label": "2 times",
      "line_style": "dashed"
    }
  ],
  "design_notes": "整体布局为左侧平台名称标签（约18%宽度），右侧水平条形图（约80%宽度），条形从左至右按相对数值（20x, 2x, 1x）比例缩放。条柱使用对应平台品牌色，并在末端标注倍数。在YouTube和TikTok条柱之间、TikTok和Kuaishou条柱之间分别添加虚线箭头，标注“10 times”和“2 times”，以强调倍数关系。标题区居中显示主标题，页脚区可留空或添加数据来源脚注。所有字体使用系统无衬线字体，主标题加粗32px，平台名称20px，数值标注14px，轴标签12px。注意保持元素对齐和适当的留白。"
}