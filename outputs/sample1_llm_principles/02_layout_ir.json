      "position": {
        "x_pct": 7,
        "y_pct": 47,
        "width_pct": 42,
        "height_pct": 18
      },
      "content_hint": "卡片内部包含图标、标题“残差连接与层归一化”和说明：缓解梯度消失，稳定深层网络训练。"
    },
    {
      "id": "card_feedforward",
      "type": "rounded_rect",
      "label": "前馈网络",
      "parent_section": "principle_section",
      "color_key": "primary",
      "importance": "primary",
