{
  "chart_type": "architecture_diagram",
  "canvas": {
    "width": 800,
    "height": 1200,
    "background": "#F5F7FB"
  },
  "color_scheme": {
    "name": "科技蓝调",
    "primary": "#2A5C8A",
    "secondary": "#F5A623",
    "accent": "#E74C3C",
    "background": "#F5F7FB",
    "text_primary": "#1A1A2E",
    "text_secondary": "#4A4A6A",
    "palette": [
      "#2A5C8A",
      "#F5A623",
      "#E74C3C",
      "#6C5CE7",
      "#00B894",
      "#FD79A8"
    ],
    "rationale": "主色调使用深蓝色，传递科技与信任感，符合大语言模型这一前沿技术主题。辅助色橙黄色用于突出关键组件（如自注意力机制），与蓝色形成鲜明对比，增强视觉层次。背景采用浅蓝灰色渐变，营造深度空间感，使上层架构图更清晰突出。"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 22,
    "body_size": 15,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 12,
    "rows": 18,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_area",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 8
      },
      "visual_weight": "primary",
      "purpose": "主标题及副标题展示"
    },
    {
      "id": "overall_flow",
      "type": "diagram",
      "position": {
        "x_pct": 0,
        "y_pct": 9,
        "width_pct": 100,
        "height_pct": 12
      },
      "visual_weight": "secondary",
      "purpose": "整体推理流程概览展示（从输入到输出）"
    },
    {
      "id": "transformer_arch",
      "type": "diagram",
      "position": {
        "x_pct": 0,
        "y_pct": 22,
        "width_pct": 100,
        "height_pct": 35
      },
      "visual_weight": "primary",
      "purpose": "Transformer架构详细分解，展示组件模块"
    },
    {
      "id": "training_pipeline",
