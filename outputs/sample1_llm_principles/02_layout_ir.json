{
  "chart_type": "concept_map",
  "canvas": {
    "width": 800,
    "height": 1200,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "科技蓝紫",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#FF6B6B",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#27AE60",
      "#F39C12",
      "#E74C3C"
    ],
    "rationale": "科技蓝紫配色适合技术概念解释，蓝色传达可靠、专业，紫色增添科技感，符合大语言模型主题。"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 22,
    "body_size": 15,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 1,
    "rows": 5,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示主标题和简短副标题"
    },
    {
      "id": "concept_map_section",
      "type": "content_block",
      "position": {
        "x_pct": 0,
        "y_pct": 10,
        "width_pct": 100,
        "height_pct": 45
      },
      "visual_weight": "primary",
      "purpose": "展示大语言模型的核心概念关系图，包含中心节点和周围组件"
    },
    {
      "id": "training_flow_section",
      "type": "timeline",
      "position": {
        "x_pct": 0,
        "y_pct": 55,
        "width_pct": 100,
        "height_pct": 20
      },
      "visual_weight": "secondary",
      "purpose": "展示训练阶段流程：预训练 → 监督微调 → RLHF"
    },
    {
      "id": "inference_flow_section",
      "type": "process_diagram",
      "position": {
        "x_pct": 0,
        "y_pct": 75,
        "width_pct": 100,
        "height_pct": 17
      },
      "visual_weight": "secondary",
      "purpose": "展示推理流程：输入文本 → Tokenization → Embedding → N层Transformer → 输出概率 → 生成文本"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 0,
        "y_pct": 92,
        "width_pct": 100,
        "height_pct": 8
      },
      "visual_weight": "tertiary",
      "purpose": "注释来源或说明"
    }
  ],
  "elements": [
    {
      "id": "title_text",
      "type": "text_block",
      "label": "大语言模型的基本原理",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "居中显示主标题，下方可加副标题 '从Transformer到ChatGPT'"
    },
    {
      "id": "central_node",
      "type": "ellipse",
      "label": "大语言模型",
      "parent_section": "concept_map_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 160,
        "min_height": 80,
        "aspect_ratio": 2
      },
      "content_hint": "中心椭圆节点，填充主色，白色文字"
    },
    {
      "id": "transformer_node",
      "type": "rounded_rect",
      "label": "Transformer架构",
      "parent_section": "concept_map_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": 2.4
      },
      "content_hint": "位于中心节点上方偏左"
    },
    {
      "id": "self_attention_node",
      "type": "rounded_rect",
      "label": "自注意力机制",
      "parent_section": "concept_map_section",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于transformer_node右侧"
    },
    {
      "id": "multi_head_attention_node",
      "type": "rounded_rect",
      "label": "多头注意力",
      "parent_section": "concept_map_section",
      "color_key": "palette[2]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于self_attention_node下方"
    },
    {
      "id": "ffn_node",
