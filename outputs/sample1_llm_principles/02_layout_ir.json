  "elements": [
    {
      "id": "title",
      "type": "text_block",
      "label": "大语言模型的基本原理",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "主标题，使用大字体加粗，水平居中，可配合装饰下划线或背景色块增强冲击力。"
    },
    {
      "id": "definition_text",
      "type": "text_block",
      "label": "大语言模型是基于Transformer架构的深度学习模型，通过自注意力机制捕捉文本中的长距离依赖关系。模型将输入文本转化为词嵌入向量，经过多头注意力层和前馈网络，逐步理解语义。",
      "parent_section": "definition_section",
      "color_key": "text_primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 500,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "简介段落，使用正文字号，行间距适中，居中对齐，简要概括模型本质。"
    },
    {
      "id": "card_word_embedding",
      "type": "rounded_rect",
      "label": "词嵌入",
      "parent_section": "principle_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 300,
        "min_height": 180,
        "aspect_ratio": null
      },
      "position": {
        "x_pct": 7,
        "y_pct": 27,
        "width_pct": 42,
        "height_pct": 18
      },
      "content_hint": "卡片内部包含图标、标题“词嵌入（Word Embedding）”和说明文字：将词语映射到高维向量空间，捕捉语义关系。"
    },
    {
      "id": "card_attention",
      "type": "rounded_rect",
      "label": "多头自注意力",
      "parent_section": "principle_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 300,
        "min_height": 180,
        "aspect_ratio": null
      },
      "position": {
        "x_pct": 51,
        "y_pct": 27,
        "width_pct": 42,
        "height_pct": 18
      },
      "content_hint": "卡片内部包含图标、标题“多头自注意力（Multi-Head Self-Attention）”和说明：多个注意力头并行计算，捕捉不同表示子空间的长距离依赖。"
    },
    {
      "id": "card_residual",
      "type": "rounded_rect",
      "label": "残差连接与层归一化",
      "parent_section": "principle_section",
      "color_key": "primary",
