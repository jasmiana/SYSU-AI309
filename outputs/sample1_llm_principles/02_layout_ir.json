      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": 2.4
      },
      "content_hint": "训练阶段第一个节点，描述：在大规模语料上学习语言模式"
    },
    {
      "id": "sft_node",
      "type": "rounded_rect",
      "label": "监督微调",
      "parent_section": "training_flow_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": 2.4
      },
      "content_hint": "训练阶段第二个节点，描述：在人工标注的指令数据上微调"
