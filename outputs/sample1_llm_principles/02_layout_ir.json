{
  "chart_type": "concept_map",
  "canvas": {
    "width": 800,
    "height": 1200,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "科技蓝紫",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#FF6B6B",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#27AE60",
      "#F39C12",
      "#FF6B6B"
    ],
    "rationale": "技术概念适合用冷静可靠的蓝紫色系，主色蓝色代表底层架构，辅色紫色表示高级训练过程，强调色红色突出关键对齐步骤（RLHF）和最终输出"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 22,
    "body_size": 15,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 4,
    "rows": 12,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 2,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "放置主标题 '大语言模型的基本原理'"
    },
    {
      "id": "transformer_section",
      "type": "diagram",
      "position": {
        "x_pct": 0,
        "y_pct": 14,
        "width_pct": 100,
        "height_pct": 45
      },
      "visual_weight": "primary",
      "purpose": "核心架构图：以'大语言模型'为中心，辐射展示Transformer各组件的概念映射"
    },
    {
      "id": "training_section",
      "type": "flowchart",
      "position": {
        "x_pct": 0,
        "y_pct": 61,
        "width_pct": 48,
        "height_pct": 22
      },
      "visual_weight": "secondary",
      "purpose": "训练流程：预训练 → 监督微调 → RLHF"
    },
    {
      "id": "inference_section",
      "type": "flowchart",
      "position": {
        "x_pct": 52,
        "y_pct": 61,
        "width_pct": 48,
        "height_pct": 22
      },
      "visual_weight": "secondary",
      "purpose": "推理流程：输入文本 → Tokenization → Embedding → N层Transformer Block → 输出概率分布 → 采样/贪心解码 → 生成文本"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 0,
        "y_pct": 88,
        "width_pct": 100,
        "height_pct": 12
      },
      "visual_weight": "tertiary",
      "purpose": "底部注释区域，可放置总结性说明或数据来源"
    }
  ],
  "elements": [
    {
      "id": "title_text",
      "type": "text_block",
      "label": "大语言模型的基本原理",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 300,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "主标题，居中显示"
    },
    {
      "id": "llm_center",
      "type": "rounded_rect",
      "label": "大语言模型",
      "parent_section": "transformer_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 160,
        "min_height": 60,
        "aspect_ratio": 2.5
      },
      "content_hint": "中心节点，使用粗体大字号"
    },
    {
      "id": "input_embedding",
      "type": "rounded_rect",
      "label": "Input Embedding\n（词嵌入）",
      "parent_section": "transformer_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "将离散词汇映射为稠密向量"
    },
    {
      "id": "positional_encoding",
      "type": "rounded_rect",
      "label": "Positional Encoding\n（位置编码）",
      "parent_section": "transformer_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "为序列添加位置信息"
    },
    {
      "id": "multi_head_attention",
      "type": "rounded_rect",
      "label": "Multi-Head\nSelf-Attention",
      "parent_section": "transformer_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "多头自注意力机制，同时关注不同位置关系"
    },
    {
      "id": "feed_forward",
      "type": "rounded_rect",
      "label": "Feed-Forward\nNetwork",
      "parent_section": "transformer_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "前馈神经网络，对每个位置的表示进行非线性变换"
    },
    {
      "id": "layer_norm",
      "type": "rounded_rect",
      "label": "Layer\nNormalization",
      "parent_section": "transformer_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "层归一化，稳定训练"
    },
    {
      "id": "residual_connection",
      "type": "rounded_rect",
      "label": "Residual\nConnection",
      "parent_section": "transformer_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "残差连接，缓解梯度消失"
    },
    {
      "id": "pt_node",
      "type": "rounded_rect",
      "label": "预训练\n(Pre-training)",
      "parent_section": "training_section",
      "color_key": "primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "在大规模语料上学习语言模式，预测下一个token"
    },
    {
      "id": "sft_node",
      "type": "rounded_rect",
      "label": "监督微调\n(SFT)",
      "parent_section": "training_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "在人工标注指令数据上微调，学会遵循指令"
    },
    {
      "id": "rlhf_node",
      "type": "rounded_rect",
      "label": "RLHF",
      "parent_section": "training_section",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "基于人类反馈的强化学习，对齐人类偏好"
    },
    {
      "id": "input_text",
      "type": "rounded_rect",
      "label": "输入文本",
      "parent_section": "inference_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 70,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "用户提供的原始文本"
    },
    {
      "id": "tokenization",
      "type": "rounded_rect",
      "label": "Tokenization",
      "parent_section": "inference_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "将文本切分为token序列"
    },
    {
      "id": "embedding",
      "type": "rounded_rect",
      "label": "Embedding",
      "parent_section": "inference_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "将token映射为向量"
    },
    {
      "id": "transformer_block",
      "type": "rounded_rect",
      "label": "N层Transformer\nBlock",
      "parent_section": "inference_section",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 100,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "核心计算模块，包含注意力、前馈网络等"
    },
    {
      "id": "output_prob",
      "type": "rounded_rect",
      "label": "输出概率分布",
      "parent_section": "inference_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "模型生成的词汇概率分布"
    },
    {
      "id": "sampling",
      "type": "rounded_rect",
      "label": "采样/贪心解码",
      "parent_section": "inference_section",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "从概率分布中选择最终输出"
    },
    {
      "id": "generated_text",
      "type": "rounded_rect",
      "label": "生成文本",
      "parent_section": "inference_section",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 70,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "最终生成的文本"
    },
    {
      "id": "footer_text",
      "type": "text_block",
      "label": "",
      "parent_section": "footer_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 200,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "可选：显示数据来源、更新时间或简短总结，例如“基于Transformer架构，通过预训练、微调与RLHF优化，生成符合人类偏好的文本。”"
    }
  ],
