      "label": "包含",
      "line_style": "solid"
    },
    {
      "id": "conn_embedding_pos",
      "type": "arrow",
      "from_element": "embedding_node",
      "to_element": "pos_encoding_node",
      "direction": "top-to-bottom",
      "label": "结合",
      "line_style": "solid"
    },
    {
      "id": "conn_transformer_residual",
      "type": "arrow",
      "from_element": "transformer_node",
      "to_element": "residual_node",
      "direction": "top-to-bottom",
      "label": "包含",
      "line_style": "solid"
    },
    {
      "id": "conn_residual_layernorm",
      "type": "arrow",
      "from_element": "residual_node",
      "to_element": "layer_norm_node",
      "direction": "left-to-right",
      "label": "配合",
      "line_style": "solid"
    },
    {
      "id": "conn_transformer_encoder",
      "type": "arrow",
      "from_element": "transformer_node",
      "to_element": "encoder_node",
      "direction": "right-to-left",
      "label": "子模块",
      "line_style": "solid"
    },
    {
      "id": "conn_transformer_decoder",
      "type": "arrow",
      "from_element": "transformer_node",
      "to_element": "decoder_node",
      "direction": "left-to-right",
      "label": "子模块",
      "line_style": "solid"
    },
    {
      "id": "conn_pretrain_sft",
      "type": "arrow",
      "from_element": "pretrain_node",
