      "id": "output_prob_node",
      "type": "rounded_rect",
      "label": "输出概率分布",
      "parent_section": "inference_flow_section",
      "color_key": "palette[4]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": 2
      },
      "content_hint": "Softmax输出"
