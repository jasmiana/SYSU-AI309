      "direction": "top-to-bottom",
      "label": "包含",
      "line_style": "solid"
    },
    {
      "id": "c_llm_to_position",
      "type": "arrow",
      "from_element": "llm_center",
      "to_element": "positional_encoding",
      "direction": "top-to-bottom",
      "label": "包含",
      "line_style": "solid"
    },
    {
      "id": "c_llm_to_attention",
      "type": "arrow",
      "from_element": "llm_center",
      "to_element": "multi_head_attention",
      "direction": "left-to-right",
      "label": "包含",
      "line_style": "solid"
    },
    {
      "id": "c_llm_to_ffn",
