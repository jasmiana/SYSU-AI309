{
  "chart_type": "concept_map",
  "canvas": {
    "width": 800,
    "height": 1100,
    "background": "#F8F9FF"
  },
  "color_scheme": {
    "name": "科技蓝紫",
    "primary": "#4A90D9",
    "secondary": "#7B68EE",
    "accent": "#FF6B6B",
    "background": "#F8F9FF",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#4A90D9",
      "#7B68EE",
      "#27AE60",
      "#F39C12",
      "#E74C3C"
    ],
    "rationale": "该主题为技术概念解释，科技蓝紫方案冷静、专业，符合人工智能领域认知，层次清晰易于阅读。"
  },
  "typography": {
    "title_size": 36,
    "heading_size": 24,
    "body_size": 14,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 8,
    "rows": 5,
    "gutter": 16
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 10,
        "y_pct": 2,
        "width_pct": 80,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示主标题，吸引注意力，确立主题"
    },
    {
      "id": "definition_section",
      "type": "content_block",
      "position": {
        "x_pct": 10,
        "y_pct": 14,
        "width_pct": 80,
        "height_pct": 9
      },
      "visual_weight": "secondary",
      "purpose": "简要定义大语言模型，为后续原理提供背景"
    },
    {
      "id": "principle_section",
      "type": "diagram",
      "position": {
        "x_pct": 5,
        "y_pct": 25,
        "width_pct": 90,
        "height_pct": 42
      },
      "visual_weight": "primary",
      "purpose": "以2x2卡片网格展示四个核心原理，直观呈现模型内部机制"
    },
    {
      "id": "flow_section",
      "type": "diagram",
      "position": {
        "x_pct": 5,
        "y_pct": 69,
        "width_pct": 90,
        "height_pct": 13
      },
      "visual_weight": "primary",
      "purpose": "横向流程展示预训练到微调再到应用的三个阶段"
    },
    {
      "id": "outcome_section",
      "type": "content_block",
      "position": {
        "x_pct": 10,
        "y_pct": 84,
        "width_pct": 80,
        "height_pct": 9
      },
      "visual_weight": "secondary",
      "purpose": "总结模型应用场景，如翻译、问答、摘要等"
