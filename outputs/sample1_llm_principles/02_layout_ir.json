    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 10,
        "y_pct": 95,
        "width_pct": 80,
        "height_pct": 5
      },
      "visual_weight": "tertiary",
      "purpose": "放置数据来源或版权备注"
    }
