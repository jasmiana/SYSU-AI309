    {
      "id": "generate_text_node",
      "type": "rounded_rect",
      "label": "生成文本",
      "parent_section": "inference_flow_section",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": 2
      },
      "content_hint": "采样/贪心解码"
    },
    {
      "id": "footer_text",
      "type": "text_block",
      "label": "参考：Transformer架构由Vaswani等人在2017年提出，后续发展出GPT、BERT等模型。",
      "parent_section": "footer_section",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 600,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "右下角小字注释"
    }
  ],
  "connections": [
    {
      "id": "conn_central_transformer",
      "type": "arrow",
      "from_element": "central_node",
      "to_element": "transformer_node",
      "direction": "top-to-bottom",
      "label": "基于",
      "line_style": "solid"
    },
    {
      "id": "conn_transformer_selfattn",
      "type": "arrow",
      "from_element": "transformer_node",
      "to_element": "self_attention_node",
      "direction": "left-to-right",
      "label": "包含",
      "line_style": "solid"
    },
    {
      "id": "conn_selfattn_multihead",
      "type": "arrow",
      "from_element": "self_attention_node",
      "to_element": "multi_head_attention_node",
      "direction": "top-to-bottom",
      "label": "扩展",
      "line_style": "solid"
    },
    {
      "id": "conn_transformer_ffn",
      "type": "arrow",
      "from_element": "transformer_node",
      "to_element": "ffn_node",
      "direction": "left-to-right",
      "label": "包含",
      "line_style": "solid"
    },
    {
      "id": "conn_transformer_embedding",
      "type": "arrow",
      "from_element": "transformer_node",
      "to_element": "embedding_node",
