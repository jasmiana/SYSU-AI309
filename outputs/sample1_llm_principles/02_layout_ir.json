      "parent_section": "concept_map_section",
      "color_key": "palette[3]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于transformer_node右侧下方"
    },
    {
      "id": "embedding_node",
      "type": "rounded_rect",
      "label": "词嵌入",
      "parent_section": "concept_map_section",
      "color_key": "palette[4]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于transformer_node左侧"
    },
    {
      "id": "pos_encoding_node",
      "type": "rounded_rect",
      "label": "位置编码",
      "parent_section": "concept_map_section",
      "color_key": "palette[0]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于embedding_node下方"
    },
    {
      "id": "residual_node",
      "type": "rounded_rect",
      "label": "残差连接",
      "parent_section": "concept_map_section",
      "color_key": "palette[1]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于transformer_node下方"
    },
    {
      "id": "layer_norm_node",
      "type": "rounded_rect",
      "label": "层归一化",
      "parent_section": "concept_map_section",
      "color_key": "palette[2]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于residual_node右侧"
    },
    {
      "id": "encoder_node",
      "type": "rounded_rect",
      "label": "编码器",
      "parent_section": "concept_map_section",
      "color_key": "palette[3]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于transformer_node左侧下方"
    },
    {
      "id": "decoder_node",
      "type": "rounded_rect",
      "label": "解码器",
      "parent_section": "concept_map_section",
      "color_key": "palette[4]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 40,
        "aspect_ratio": 2.5
      },
      "content_hint": "位于transformer_node右侧下方"
    },
    {
      "id": "pretrain_node",
