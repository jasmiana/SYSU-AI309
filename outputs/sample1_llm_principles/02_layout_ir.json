      "direction": "left-to-right",
      "label": "下一步",
      "line_style": "solid"
    },
    {
      "id": "conn_sft_rlhf",
      "type": "arrow",
      "from_element": "sft_node",
      "to_element": "rlhf_node",
      "direction": "left-to-right",
      "label": "下一步",
      "line_style": "solid"
    },
    {
      "id": "conn_input_tokenization",
      "type": "arrow",
      "from_element": "input_text_node",
      "to_element": "tokenization_node",
      "direction": "left-to-right",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn_tokenization_embedding",
      "type": "arrow",
      "from_element": "tokenization_node",
