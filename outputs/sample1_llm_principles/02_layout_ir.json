      "content_hint": "推理流程起始节点"
    },
    {
      "id": "tokenization_node",
      "type": "rounded_rect",
      "label": "Tokenization",
      "parent_section": "inference_flow_section",
      "color_key": "palette[1]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": 2
      },
      "content_hint": "分词"
    },
    {
      "id": "embedding_node2",
      "type": "rounded_rect",
      "label": "Embedding",
      "parent_section": "inference_flow_section",
      "color_key": "palette[2]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 80,
        "min_height": 40,
        "aspect_ratio": 2
      },
      "content_hint": "词嵌入+位置编码"
    },
    {
      "id": "transformer_block_node",
      "type": "rounded_rect",
      "label": "N层Transformer\nBlock",
      "parent_section": "inference_flow_section",
      "color_key": "palette[3]",
      "importance": "secondary",
      "size_hint": {
        "min_width": 100,
        "min_height": 50,
        "aspect_ratio": 2
      },
      "content_hint": "多层Transformer块"
    },
