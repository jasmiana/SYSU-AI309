{
  "chart_type": "process_diagram",
  "canvas": {
    "width": 800,
    "height": 1200,
    "background": "#FFF8F0"
  },
  "color_scheme": {
    "name": "咖啡醇香",
    "primary": "#8B5A2B",
    "secondary": "#D2B48C",
    "accent": "#A0522D",
    "background": "#FFF8F0",
    "text_primary": "#4A3622",
    "text_secondary": "#8B7355",
    "palette": [
      "#8B5A2B",
      "#D2B48C",
      "#A0522D",
      "#FFF8F0",
      "#4A3622",
      "#8B7355"
    ],
    "rationale": "采用咖啡主题的暖棕色系，从浅奶白背景到深烘焙棕，突出醇厚、自然的生产流程，与咖啡文化紧密契合。"
  },
  "typography": {
    "title_size": 36,
    "heading_size": 20,
    "body_size": 16,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 12,
    "rows": 12,
    "gutter": 20
  },
  "sections": [
    {
      "id": "title_section",
      "type": "title",
      "position": {
        "x_pct": 10,
        "y_pct": 0,
        "width_pct": 80,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示流程图主标题，吸引注意力"
    },
    {
      "id": "process_section",
      "type": "diagram",
      "position": {
        "x_pct": 10,
        "y_pct": 12,
        "width_pct": 80,
        "height_pct": 78
      },
      "visual_weight": "primary",
      "purpose": "包含从咖啡豆到一杯咖啡的完整流程节点和箭头连接"
    },
    {
      "id": "footer_section",
      "type": "footer",
      "position": {
        "x_pct": 0,
        "y_pct": 92,
        "width_pct": 100,
        "height_pct": 8
      },
      "visual_weight": "tertiary",
      "purpose": "放置版权、说明等辅助信息"
    }
  ],
  "elements": [
    {
      "id": "main_title",
      "type": "text_block",
      "label": "从咖啡豆到一杯咖啡的生产链",
      "parent_section": "title_section",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "显示为居中的大号标题，使用主标题字号，可搭配咖啡豆装饰图形"
    },
    {
      "id": "start_node",
      "type": "rounded_rect",
      "label": "咖啡豆",
      "parent_section": "process_section",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 160,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "流程起点，圆角矩形，内部显示文字，可添加咖啡豆图标"
    },
    {
      "id": "step_1",
      "type": "rounded_rect",
