{
  "chart_type": "process_diagram",
  "canvas": {
    "width": 800,
    "height": 1300,
    "background": "#FAFFFE"
  },
  "color_scheme": {
    "name": "自然清新",
    "primary": "#27AE60",
    "secondary": "#3498DB",
    "accent": "#F39C12",
    "background": "#FAFFFE",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#27AE60",
      "#3498DB",
      "#F39C12",
      "#E74C3C",
      "#2C3E50"
    ],
    "rationale": "咖啡生产是自然到成品的转化过程，选择自然清新的绿色主调象征植物生长，蓝色辅助代表水与科技，橙色点缀体现烘焙的温暖与活力。"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 22,
    "body_size": 15,
    "label_size": 14,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 1,
    "rows": 6,
    "gutter": 30
  },
  "sections": [
    {
      "id": "header",
      "type": "title",
      "position": {
        "x_pct": 5,
        "y_pct": 2,
        "width_pct": 90,
        "height_pct": 8
      },
      "visual_weight": "primary",
      "purpose": "展示主标题：从咖啡豆到一杯咖啡的完整生产链"
    },
    {
      "id": "flow_area",
      "type": "diagram",
      "position": {
        "x_pct": 10,
        "y_pct": 12,
        "width_pct": 80,
        "height_pct": 85
      },
      "visual_weight": "primary",
      "purpose": "包含7个流程节点（起始、5个步骤、结束）以及连接它们的箭头"
    }
  ],
  "elements": [
    {
      "id": "start",
      "type": "ellipse",
      "label": "咖啡豆",
      "parent_section": "flow_area",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "流程起始：生豆原料"
    },
    {
      "id": "planting",
      "type": "rounded_rect",
      "label": "种植",
      "parent_section": "flow_area",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 200,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "咖啡农培育咖啡树，待咖啡果成熟后进入采摘环节。"
    },
    {
      "id": "harvesting",
      "type": "rounded_rect",
      "label": "采摘",
      "parent_section": "flow_area",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 200,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "通过手工或机械方式收获成熟的咖啡果实，并进行初步处理以获取生豆。"
    },
    {
      "id": "roasting",
      "type": "rounded_rect",
      "label": "烘焙",
      "parent_section": "flow_area",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 200,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "将生豆放入烘焙机高温加热，使其发生物理化学变化，形成咖啡特有的风味。"
    },
    {
      "id": "grinding",
      "type": "rounded_rect",
      "label": "研磨",
      "parent_section": "flow_area",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 200,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "将烘焙好的咖啡豆研磨成粗细适中的咖啡粉。"
    },
    {
      "id": "brewing",
      "type": "rounded_rect",
      "label": "冲煮",
      "parent_section": "flow_area",
      "color_key": "primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 200,
        "min_height": 60,
        "aspect_ratio": null
      },
      "content_hint": "通过热水萃取咖啡粉，得到最终的咖啡饮品。"
    },
    {
      "id": "end",
      "type": "ellipse",
      "label": "一杯咖啡",
      "parent_section": "flow_area",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 120,
        "min_height": 50,
        "aspect_ratio": null
      },
      "content_hint": "最终成品：一杯香浓咖啡"
    }
  ],
  "connections": [
    {
      "id": "conn1",
      "type": "arrow",
      "from_element": "start",
      "to_element": "planting",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn2",
      "type": "arrow",
      "from_element": "planting",
      "to_element": "harvesting",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn3",
      "type": "arrow",
      "from_element": "harvesting",
      "to_element": "roasting",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn4",
      "type": "arrow",
      "from_element": "roasting",
      "to_element": "grinding",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn5",
      "type": "arrow",
      "from_element": "grinding",
      "to_element": "brewing",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn6",
      "type": "arrow",
      "from_element": "brewing",
      "to_element": "end",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    }
  ],
  "design_notes": "整体采用现代简约风格，垂直流程清晰易读。节点使用圆角矩形（过程）和椭圆（起止）区分，搭配柔和阴影和渐变，箭头光滑连接。配色选用自然清新的绿色主调，象征植物生长，点缀橙色突出起点与终点。可在背景或角落添加半透明的咖啡豆、叶片等装饰元素，增强主题氛围。文字排版主次分明，标题醒目，描述清晰，确保从‘咖啡豆’到‘一杯咖啡’的完整旅程流畅且富有美感。节点内可放置简短图标，如叶片、咖啡豆、烘焙火焰、研磨器、咖啡杯等，增强视觉识别。"
}