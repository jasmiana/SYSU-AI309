{
  "chart_type": "flowchart",
  "canvas": {
    "width": 800,
    "height": 1000,
    "background": "#FAFFFE"
  },
  "color_scheme": {
    "name": "自然清新",
    "primary": "#27AE60",
    "secondary": "#3498DB",
    "accent": "#F39C12",
    "background": "#FAFFFE",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#27AE60",
      "#3498DB",
      "#F39C12",
      "#E74C3C"
    ],
    "rationale": "采用自然清新配色，绿色代表种植与自然，蓝色象征水与萃取过程，橙色突出烘焙环节，整体清新且贴合咖啡主题。"
  },
  "typography": {
    "title_size": 32,
    "heading_size": 20,
    "body_size": 14,
    "label_size": 12,
    "font_family": "system-ui, 'Microsoft YaHei', sans-serif"
  },
  "layout_grid": {
    "columns": 1,
    "rows": 7,
    "gutter": 30
  },
  "sections": [
    {
      "id": "title",
      "type": "title",
      "position": {
        "x_pct": 0,
        "y_pct": 0,
        "width_pct": 100,
        "height_pct": 10
      },
      "visual_weight": "primary",
      "purpose": "展示流程图主标题"
    },
    {
      "id": "step1",
      "type": "content_block",
      "position": {
        "x_pct": 10,
        "y_pct": 14,
        "width_pct": 80,
        "height_pct": 12
      },
      "visual_weight": "secondary",
      "purpose": "种植环节：咖啡树生长并结出咖啡果，果实内含咖啡豆"
    },
    {
      "id": "step2",
      "type": "content_block",
      "position": {
        "x_pct": 10,
        "y_pct": 30,
        "width_pct": 80,
        "height_pct": 12
      },
      "visual_weight": "secondary",
      "purpose": "采摘环节：成熟咖啡果被手工或机械采摘，取出咖啡豆（生豆）"
    },
    {
      "id": "step3",
      "type": "content_block",
      "position": {
        "x_pct": 10,
        "y_pct": 46,
        "width_pct": 80,
        "height_pct": 12
      },
      "visual_weight": "secondary",
      "purpose": "烘焙环节：生豆在高温下烘焙，产生香气和风味，颜色变深成为熟豆"
    },
    {
      "id": "step4",
      "type": "content_block",
      "position": {
        "x_pct": 10,
        "y_pct": 62,
        "width_pct": 80,
        "height_pct": 12
      },
      "visual_weight": "secondary",
      "purpose": "研磨环节：熟豆被研磨成细粉，增加萃取面积"
    },
    {
      "id": "step5",
      "type": "content_block",
      "position": {
        "x_pct": 10,
        "y_pct": 78,
        "width_pct": 80,
        "height_pct": 12
      },
      "visual_weight": "secondary",
      "purpose": "冲煮环节：咖啡粉与热水接触，通过萃取得到一杯香浓咖啡"
    }
  ],
  "elements": [
    {
      "id": "title_text",
      "type": "text_block",
      "label": "从咖啡豆到咖啡的完整生产链流程图",
      "parent_section": "title",
      "color_key": "text_primary",
      "importance": "primary",
      "size_hint": {
        "min_width": 400,
        "min_height": 40,
        "aspect_ratio": null
      },
      "content_hint": "主标题，居中对齐，加粗，字号32px"
    },
    {
      "id": "node1",
      "type": "rounded_rect",
      "label": "种植",
      "parent_section": "step1",
      "color_key": "primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "圆角矩形，填充主色（#27AE60），白色文字，内部包含步骤名称（加粗20px）和描述（14px）"
    },
    {
      "id": "node2",
      "type": "rounded_rect",
      "label": "采摘",
      "parent_section": "step2",
      "color_key": "primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "同node1"
    },
    {
      "id": "node3",
      "type": "rounded_rect",
      "label": "烘焙",
      "parent_section": "step3",
      "color_key": "accent",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "使用强调色（#F39C12）表示烘焙高温变化"
    },
    {
      "id": "node4",
      "type": "rounded_rect",
      "label": "研磨",
      "parent_section": "step4",
      "color_key": "secondary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "使用辅色（#3498DB）"
    },
    {
      "id": "node5",
      "type": "rounded_rect",
      "label": "冲煮",
      "parent_section": "step5",
      "color_key": "primary",
      "importance": "secondary",
      "size_hint": {
        "min_width": 200,
        "min_height": 80,
        "aspect_ratio": null
      },
      "content_hint": "回归主色，表示成品"
    },
    {
      "id": "desc1",
      "type": "text_block",
      "label": "咖啡树生长 → 咖啡果",
      "parent_section": "step1",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 150,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "放置在节点下方或内部，14px正文描述"
    },
    {
      "id": "desc2",
      "type": "text_block",
      "label": "采摘成熟咖啡果 → 生豆",
      "parent_section": "step2",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 150,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "同上"
    },
    {
      "id": "desc3",
      "type": "text_block",
      "label": "高温烘焙 → 香气 & 风味",
      "parent_section": "step3",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 150,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "同上"
    },
    {
      "id": "desc4",
      "type": "text_block",
      "label": "研磨 → 细粉",
      "parent_section": "step4",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 150,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "同上"
    },
    {
      "id": "desc5",
      "type": "text_block",
      "label": "热水萃取 → 一杯咖啡",
      "parent_section": "step5",
      "color_key": "text_secondary",
      "importance": "tertiary",
      "size_hint": {
        "min_width": 150,
        "min_height": 30,
        "aspect_ratio": null
      },
      "content_hint": "同上"
    }
  ],
  "connections": [
    {
      "id": "arrow1",
      "type": "arrow",
      "from_element": "node1",
      "to_element": "node2",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "arrow2",
      "type": "arrow",
      "from_element": "node2",
      "to_element": "node3",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "arrow3",
      "type": "arrow",
      "from_element": "node3",
      "to_element": "node4",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "arrow4",
      "type": "arrow",
      "from_element": "node4",
      "to_element": "node5",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    }
  ],
  "design_notes": "整体垂直流程图，标题居中，节点水平居中于画布。每个节点使用圆角矩形，宽度自适应（最小200px）。节点背景色主色（绿色）用于种植、冲煮；强调色（橙色）用于烘焙；辅色（蓝色）用于研磨，以视觉区分不同工艺阶段。节点内部文字：步骤名称（加粗20px）在上，描述（14px常规）在下，文字颜色为白色（#FFFFFF）。箭头使用主色（#27AE60），线宽2px，从上一节点底部中心指向下一节点顶部中心。画布四周留白40px，节点间距30px。最终效果应清晰、简洁，符合咖啡生产链的流程逻辑。"
}