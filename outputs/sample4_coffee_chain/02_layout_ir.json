{
  "chart_type": "process_diagram",
  "canvas": {
    "width": 800,
    "height": 1300,
    "background": "#FAFFFE"
  },
  "color_scheme": {
    "name": "自然清新",
    "primary": "#27AE60",
    "secondary": "#3498DB",
    "accent": "#F39C12",
    "background": "#FAFFFE",
    "text_primary": "#2C3E50",
    "text_secondary": "#7F8C8D",
    "palette": [
      "#27AE60",
      "#3498DB",
      "#F39C12",
      "#E74C3C",
      "#9B59B6"
    ],
    "rationale": "咖啡生产链涉及植物生长与自然过程，绿色作为主色调代表种植与采摘；蓝色辅助代表烘焙与冲煮中的水元素；金色强调烘焙的焦糖化反应与最终咖啡的醇厚质感，整体清新自然，符合从果实到饮品的叙事。"
  },
