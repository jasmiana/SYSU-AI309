      "id": "conn_start_step1",
      "type": "arrow",
      "from_element": "start_node",
      "to_element": "step_1",
      "direction": "top-to-bottom",
      "label": null,
      "line_style": "solid"
    },
    {
      "id": "conn_step1_step2",
