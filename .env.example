# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek Model Configuration
# Primary: deepseek-v4-pro  (powerful reasoning, default)
# Fallback: deepseek-v4-flash (faster, lighter)
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FALLBACK_MODEL=deepseek-v4-flash

# DeepSeek API Base URL (default)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Thinking / Reasoning Mode (DeepSeek native)
# When enabled, the model outputs chain-of-thought reasoning tokens
THINKING_ENABLED=true
REASONING_EFFORT=high
